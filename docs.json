{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Universal Object Mapping (UOM) Assistant Documentation",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global":  {
      "anchors": [
        {
          "anchor": "UOM Backend API Reference",
          "icon": "square-terminal",
          "href": "https://api.uom.dyn.cloud.e-infra.cz/docs"
        },
        {
          "anchor": "UOM Daytona API Reference",
          "icon": "square-terminal",
          "href": "https://daytona.uom.dyn.cloud.e-infra.cz/api"
        }
      ]
    },
    "groups": [
      {
        "group": "Introduction",
        "icon": "rocket",
        "pages": [
          "index"
        ]
      },
      {
        "group": "User Docs",
        "icon": "book-open",
        "pages": [
          "user_guide"
        ]
      },
      {
        "group": "Developer Docs",
        "directory": "card",
        "icon": "code",
        "pages": [
          {
            "group": "Backend",
            "expanded": true,
            "pages": [
              "backend/architecture",
              "backend/state_and_context",
              "backend/sandbox_environment",
              "backend/validators_and_equivalence",
              "backend/deep_agent_and_acp",
              "backend/mcp_integration"
            ]
          },
          {
            "group": "Frontend",
            "expanded": true,
            "pages": [
              "frontend/overview",
              "frontend/architecture",
              "frontend/runtime",
              "frontend/components",
              "frontend/setup"
            ]
          },
          {
            "group": "DevOps",
            "expanded": true,
            "pages": [
              "devops/devops"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:martincorovcak@gmail.com"
      }
