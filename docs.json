{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Universal Object Mapping (UOM) Assistant Documentation",
  "colors": {
    "primary": "#5441fe",
    "light": "#6f75ff",
    "dark": "#5441fe"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "UOM Backend API Reference",
          "icon": "square-terminal",
          "href": "https://api.uom.dyn.cloud.e-infra.cz/docs"
        },
        {
          "anchor": "UOM Daytona API Reference",
          "icon": "square-terminal",
          "href": "https://daytona.uom.dyn.cloud.e-infra.cz/api"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Introduction",
            "icon": "rocket",
            "pages": [
              "index"
            ]
          },
          {
            "group": "User Docs",
            "icon": "book-open",
            "pages": [
              "user_docs/user_guide"
            ]
          },
          {
            "group": "Developer Docs",
            "directory": "card",
            "icon": "code",
            "pages": [
              {
                "group": "Backend",
                "expanded": true,
                "pages": [
                  "developer_docs/backend/architecture",
                  "developer_docs/backend/state_and_context",
                  "developer_docs/backend/sandbox_environment",
                  "developer_docs/backend/validators_and_equivalence",
                  "developer_docs/backend/deep_agent_and_acp",
                  "developer_docs/backend/mcp_integration"
                ]
              },
              {
                "group": "Frontend",
                "expanded": true,
                "pages": [
                  "developer_docs/frontend/overview",
                  "developer_docs/frontend/architecture",
                  "developer_docs/frontend/runtime",
                  "developer_docs/frontend/components",
                  "developer_docs/frontend/setup"
                ]
              },
              {
                "group": "DevOps",
                "expanded": true,
                "pages": [
                  "developer_docs/devops/devops"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Backend Code Reference",
        "directory": "accordion",
        "groups": [
          {
            "group": "UOM Translator (LangGraph)",
