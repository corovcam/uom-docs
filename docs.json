              "frontend_code_reference/components/ide-link",
              "frontend_code_reference/components/json-viewer",
              "frontend_code_reference/components/streamdown-text"
            ]
          },
          {
            "group": "hooks",
            "pages": [
              "frontend_code_reference/hooks/use-app-context",
              "frontend_code_reference/hooks/use-graph-state-context",
              "frontend_code_reference/hooks/use-mobile"
            ]
          },
          {
            "group": "lib",
            "pages": [
              "frontend_code_reference/lib/chatApi",
              "frontend_code_reference/lib/types",
              "frontend_code_reference/lib/utils"
            ]
          }
        ],
        "directory": "accordion"
      }
    ]
  },
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
