                "group": "Custom Tools",
                "pages": [
                  "backend_code_reference/react_agent/custom_tools/docs_search",
                  "backend_code_reference/react_agent/custom_tools/dotnet_validator",
                  "backend_code_reference/react_agent/custom_tools/java_validator",
                  "backend_code_reference/react_agent/custom_tools/mcp_database",
                  "backend_code_reference/react_agent/custom_tools/query_validator",
                  "backend_code_reference/react_agent/custom_tools/sandbox_tools"
                ]
              },
              {
                "group": "Utils",
                "pages": [
                  "backend_code_reference/react_agent/utils/deterministic_checks",
                  "backend_code_reference/react_agent/utils/preprocessing",
                  "backend_code_reference/react_agent/utils/request_logging",
